# Git LFS 추적 설정 — 대용량/바이너리 산출물
# CAD (SolidWorks / STEP / ANSYS)
*.SLDPRT  filter=lfs diff=lfs merge=lfs -text
*.sldprt  filter=lfs diff=lfs merge=lfs -text
*.SLDASM  filter=lfs diff=lfs merge=lfs -text
*.sldasm  filter=lfs diff=lfs merge=lfs -text
*.STEP    filter=lfs diff=lfs merge=lfs -text
*.step    filter=lfs diff=lfs merge=lfs -text
*.STP     filter=lfs diff=lfs merge=lfs -text
*.stp     filter=lfs diff=lfs merge=lfs -text
*.agdb    filter=lfs diff=lfs merge=lfs -text
*.mechdb  filter=lfs diff=lfs merge=lfs -text
*.wbpj    filter=lfs diff=lfs merge=lfs -text
*.dsco    filter=lfs diff=lfs merge=lfs -text
*.rst     filter=lfs diff=lfs merge=lfs -text
*.CWR     filter=lfs diff=lfs merge=lfs -text
*.GEN     filter=lfs diff=lfs merge=lfs -text
# 영상
*.mp4     filter=lfs diff=lfs merge=lfs -text
# 문서 / 발표 / 데이터
*.pdf     filter=lfs diff=lfs merge=lfs -text
*.pptx    filter=lfs diff=lfs merge=lfs -text
*.xlsx    filter=lfs diff=lfs merge=lfs -text
*.hwp     filter=lfs diff=lfs merge=lfs -text
*.hwpx    filter=lfs diff=lfs merge=lfs -text
# 압축 / 펌웨어 / Fritzing
*.zip     filter=lfs diff=lfs merge=lfs -text
*.hex     filter=lfs diff=lfs merge=lfs -text
*.fzz     filter=lfs diff=lfs merge=lfs -text
*.fzpz    filter=lfs diff=lfs merge=lfs -text
# 큰 사진(촬영본). 작은 다이어그램 PNG는 일반 git으로 둬서 README 인라인 표시 유지
*.jpg     filter=lfs diff=lfs merge=lfs -text
*.jpeg    filter=lfs diff=lfs merge=lfs -text
*.JPG     filter=lfs diff=lfs merge=lfs -text
*.docx filter=lfs diff=lfs merge=lfs -text
